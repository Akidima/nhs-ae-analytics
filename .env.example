# =====================================================================
# NHS A&E Analytics — environment template
# Copy to `.env` and adjust. NEVER commit the real `.env`.
#   cp .env.example .env
# These are LOCAL DEV credentials only — fine to be simple.
# =====================================================================

# ---------------- PostgreSQL (analytics warehouse) ----------------
POSTGRES_USER=nhs
POSTGRES_PASSWORD=nhs_local_pw
POSTGRES_DB=nhs_ae
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Convenience connection string used by the ingestion app + dbt
NHS_AE_DB_URL=postgresql+psycopg2://nhs:nhs_local_pw@postgres:5432/nhs_ae

# ---------------- MinIO (raw zone, S3-compatible) -----------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_local_pw
MINIO_ENDPOINT=http://minio:9000
RAW_BUCKET=nhs-ae-raw
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin_local_pw
AWS_DEFAULT_REGION=eu-west-2

# ---------------- LocalStack (AWS emulator, Phase 10) -------------
LOCALSTACK_ENDPOINT=http://localstack:4566

# ---------------- Airflow -----------------------------------------
# Metadata DB lives in the same Postgres instance (separate database).
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://nhs:nhs_local_pw@postgres:5432/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
# Generate your own with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=True
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
AIRFLOW_UID=50000

# ---------------- Pipeline config ---------------------------------
NHS_AE_LANDING_PAGE=https://www.england.nhs.uk/statistics/statistical-work-areas/ae-waiting-times-and-activity/
LOG_LEVEL=INFO
